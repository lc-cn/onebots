{
  "name": "@onebots/adapter-wechat-clawbot",
  "version": "1.1.0",
  "description": "OneBots 微信扩展 ClawBot（iLink Bot HTTP）适配器：扫码登录、长轮询、会话持久化与媒体收发",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "rm -f *.tsbuildinfo && tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
    "clean": "rm -rf lib *.tsbuildinfo"
  },
  "keywords": [
    "onebots",
    "wechat-clawbot",
    "clawbot",
    "ilink",
    "wechat",
    "adapter"
  ],
  "author": "凉菜",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "/lib/**/*.js",
    "/lib/**/*.d.ts"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsc-alias": "latest",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "onebots": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lc-cn/onebots.git"
  }
}
